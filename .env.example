# ── Anthropic API ──────────────────────────────────────────────────────────────
# Your Anthropic API key — required for LLM extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Platform API Key ──────────────────────────────────────────────────────────
# Optional: if set, all API calls must include X-API-Key: <this value>
# Leave blank (or remove) for open/dev mode (no auth required)
MOP_API_KEY=

# ── Worker pool ───────────────────────────────────────────────────────────────
# How many documents can be processed concurrently (each consumes an LLM quota)
MAX_WORKERS=3

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO        # Console log level: DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs          # Directory for rotating log files (logs/mop_api.log)
